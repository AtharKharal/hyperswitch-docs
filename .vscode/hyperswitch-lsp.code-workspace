{
  "folders": [
    {
      "name": "HyperSwitch",
      "path": "."
    }
  ],
  "settings": {
    "json.schemas": [
      {
        "fileMatch": ["*hyperswitch*.json", "*payment*.json"],
        "url": "./.vscode/hyperswitch.schema.json"
      }
    ],
    "editor.quickSuggestions": {
      "comments": true,
      "strings": true,
      "other": true
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.tabCompletion": "on"
  }
}